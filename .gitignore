# ============================================
# Unity .gitignore — Y WONDER GREEN FARM
# ============================================

# Unity generated
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures
/[Mm]emory[Cc]aptures/

# Recordings
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# TextMeshPro
/[Aa]ssets/TextMesh Pro/

# ============================================
# OS generated
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# IDE
# ============================================
.vs/
.vscode/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
.idea/
*.iml

# ============================================
# Antigravity / AI
# ============================================
.gemini/

Assets/Building/Map1*

# ============================================
# Build temp + texture NPC gốc nặng (391MB) — extract lại được từ .glb (22/06)
# ============================================
/.utmp/
/Assets/OptimizedNPCAssets/
/Assets/OptimizedNPCAssets.meta
