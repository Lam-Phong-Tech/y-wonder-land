# Unity files — tell GitHub Linguist to ignore
*.meta linguist-generated
*.asset linguist-generated
*.unity linguist-generated
*.prefab linguist-generated
*.mat linguist-generated
*.controller linguist-generated
*.anim linguist-generated
*.physicMaterial linguist-generated
*.physicsMaterial2D linguist-generated
*.lighting linguist-generated
*.giparams linguist-generated
*.renderTexture linguist-generated
*.spriteatlas linguist-generated
*.terrainlayer linguist-generated
*.shadergraph linguist-generated
*.shadersubgraph linguist-generated
# Schema files
*.xsd linguist-generated
# Docs — not code
*.md linguist-documentation
*.fbx filter=lfs diff=lfs merge=lfs -text

# Pre-exported Unity iOS Xcode projects contain Mach-O/.NET runtime binaries.
# Treat the export as binary by default; opt text/source files back in below.
/ios/** -text
/ios/**/*.c text eol=lf
/ios/**/*.cc text eol=lf
/ios/**/*.cpp text eol=lf
/ios/**/*.h text eol=lf
/ios/**/*.hpp text eol=lf
/ios/**/*.m text eol=lf
/ios/**/*.mm text eol=lf
/ios/**/*.cs text eol=lf
/ios/**/*.json text eol=lf
/ios/**/*.plist text eol=lf
/ios/**/*.pbxproj text eol=lf
/ios/**/*.xcscheme text eol=lf
/ios/**/*.xcworkspacedata text eol=lf
/ios/**/*.xcconfig text eol=lf
/ios/**/*.entitlements text eol=lf
/ios/**/*.storyboard text eol=lf
/ios/**/*.sh text eol=lf
/ios/**/*.txt text eol=lf
/ios/**/*.a filter=lfs diff=lfs merge=lfs -text
/ios/**/*.resS filter=lfs diff=lfs merge=lfs -text
/ios/usymtool filter=lfs diff=lfs merge=lfs -text
/ios/usymtoolarm64 filter=lfs diff=lfs merge=lfs -text
