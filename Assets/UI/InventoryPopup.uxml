<?xml version="1.0" encoding="utf-8"?>
<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:Style src="project://database/Assets/UI/Styles/DesignSystem.uss" />
    <ui:Style src="project://database/Assets/UI/Styles/InventoryPopup.uss" />

    <!-- Overlay -->
    <ui:VisualElement name="InventoryOverlay" class="inventory-overlay">

        <!-- Panel Shadow -->
        <ui:VisualElement class="inventory-panel-shadow">

            <!-- Panel -->
            <ui:VisualElement class="inventory-panel">

                <!-- Header -->
                <ui:VisualElement class="inventory-header">
                    <ui:Label text="KHO ĐỒ" class="inventory-header-title" />
                </ui:VisualElement>

                <!-- Body: Tabs + Grid -->
                <ui:VisualElement class="inventory-body">

                    <!-- Left: Category Tabs -->
                    <ui:VisualElement class="inventory-tabs">
                        <ui:Button name="TabTools" text="Dụng cụ" class="inventory-tab inventory-tab--active" />
                        <ui:Button name="TabMaterials" text="Nguyên liệu" class="inventory-tab" />
                        <ui:Button name="TabSeeds" text="Hạt giống" class="inventory-tab" />
                        <ui:Button name="TabFood" text="Thực phẩm" class="inventory-tab" />
                        <ui:Button name="TabOutfit" text="Trang phục" class="inventory-tab" />
                        <ui:Button name="TabSpecial" text="Đặc biệt" class="inventory-tab" />
                    </ui:VisualElement>

                    <!-- Right: Items Grid -->
                    <ui:VisualElement class="inventory-grid-area">
                        <ui:ScrollView name="InventoryScroll" class="inventory-grid-scroll">
                            <ui:VisualElement name="InventoryGrid" class="inventory-grid">

                                <!-- Mock items (will be populated by controller) -->
                                <ui:VisualElement class="inventory-item-shadow">
                                    <ui:VisualElement class="inventory-item">
                                        <ui:VisualElement class="inventory-item-icon">
                                            <ui:Label text="⛏" class="inventory-item-icon-text" />
                                        </ui:VisualElement>
                                        <ui:Label text="Cuốc Lv1" class="inventory-item-name" />
                                        <ui:Label text="x1" class="inventory-item-qty" />
                                    </ui:VisualElement>
                                </ui:VisualElement>

                                <ui:VisualElement class="inventory-item-shadow">
                                    <ui:VisualElement class="inventory-item">
                                        <ui:VisualElement class="inventory-item-icon">
                                            <ui:Label text="🎣" class="inventory-item-icon-text" />
                                        </ui:VisualElement>
                                        <ui:Label text="Cần câu" class="inventory-item-name" />
                                        <ui:Label text="x1" class="inventory-item-qty" />
                                    </ui:VisualElement>
                                </ui:VisualElement>

                                <ui:VisualElement class="inventory-item-shadow">
                                    <ui:VisualElement class="inventory-item">
                                        <ui:VisualElement class="inventory-item-icon">
                                            <ui:Label text="🪓" class="inventory-item-icon-text" />
                                        </ui:VisualElement>
                                        <ui:Label text="Rìu gỗ" class="inventory-item-name" />
                                        <ui:Label text="x1" class="inventory-item-qty" />
                                    </ui:VisualElement>
                                </ui:VisualElement>

                                <ui:VisualElement class="inventory-item-shadow">
                                    <ui:VisualElement class="inventory-item">
                                        <ui:VisualElement class="inventory-item-icon">
                                            <ui:Label text="🪣" class="inventory-item-icon-text" />
                                        </ui:VisualElement>
                                        <ui:Label text="Xô tưới" class="inventory-item-name" />
                                        <ui:Label text="x2" class="inventory-item-qty" />
                                    </ui:VisualElement>
                                </ui:VisualElement>

                            </ui:VisualElement>
                        </ui:ScrollView>
                    </ui:VisualElement>

                </ui:VisualElement>

                <!-- Bottom Info Bar -->
                <ui:VisualElement class="inventory-info-bar">
                    <ui:Label name="LblItemCount" text="4 / 50 vật phẩm" class="inventory-info-text" />
                    <ui:Label name="LblCategory" text="Dụng cụ" class="inventory-info-text" />
                </ui:VisualElement>

            </ui:VisualElement>

            <!-- Close Button (AFTER panel → renders on top) -->
            <ui:VisualElement class="inventory-close-shadow">
                <ui:Button name="BtnCloseInventory" text="✕" class="inventory-close-btn" />
            </ui:VisualElement>

        </ui:VisualElement>

    </ui:VisualElement>

</ui:UXML>
